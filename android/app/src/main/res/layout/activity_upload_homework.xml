<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        style="@style/AppToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:navigationIcon="@android:drawable/ic_media_previous"
        android:title="上传作业" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- 作业标题 -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="作业标题"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="20dp" />

            <!-- 图片预览区域 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="260dp"
                style="@style/CardStyle">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/ivPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="作业图片预览" />

                    <!-- 占位文字（未选图时显示） -->
                    <LinearLayout
                        android:id="@+id/llPlaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@color/surface_variant">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📷"
                            android:textSize="48sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="请拍照或选择作业图片"
                            android:textSize="15sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- 提示信息 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💡 提示：请保持图片清晰，确保所有答题内容完整可见，支持 JPG/PNG 格式，最大 10MB"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:background="@color/pending_bg"
                android:padding="12dp"
                android:layout_marginBottom="20dp" />

            <!-- 拍照和相册按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCamera"
                    style="@style/OutlineButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="📷 拍照" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGallery"
                    style="@style/OutlineButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="🖼 相册" />
            </LinearLayout>

            <!-- 进度条 -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_gravity="center"
                android:layout_marginBottom="8dp" />

            <!-- 提交按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpload"
                style="@style/PrimaryButton"
                android:text="🚀 提交作业"
                android:enabled="false" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
